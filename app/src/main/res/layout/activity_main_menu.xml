<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <!-- 背景图片 -->
    <ImageView
        android:id="@+id/image"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="true"
        android:scaleType="centerCrop"
        android:src="@drawable/bg_start" />

    <!-- 标题 -->
    <TextView
        android:id="@+id/title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:fontFamily="serif"
        android:text="飞机大战"
        android:textColor="#FFFFFF"
        android:textSize="90sp"
        android:textStyle="bold"
        android:layout_marginTop="150dp"
        android:shadowColor="#9D71FF"
        android:shadowDx="0"
        android:shadowDy="0"
        android:shadowRadius="30"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- 音乐开关 RadioGroup -->
    <RadioGroup
        android:id="@+id/radio_group"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginTop="25dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/title">

        <RadioButton
            android:id="@+id/radio_on"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="开启音乐"
            android:textColor="@android:color/holo_purple"
            android:textSize="25sp"
            android:shadowColor="#000000"
            android:shadowDx="5"
            android:shadowDy="5"
            android:shadowRadius="5"
            app:buttonTint="@android:color/holo_purple" />

        <RadioButton
            android:id="@+id/radio_off"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="关闭音乐"
            android:textColor="@android:color/holo_purple"
            android:textSize="25sp"
            android:shadowColor="#000000"
            android:shadowDx="5"
            android:shadowDy="5"
            android:shadowRadius="5"
            app:buttonTint="@android:color/holo_purple" />

    </RadioGroup>

    <!-- 单机模式按钮 -->
    <Button
        android:id="@+id/btn_single"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="单机模式"
        android:textSize="25sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:layout_marginTop="40dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/radio_group" />

    <!-- 联机模式按钮 -->
    <Button
        android:id="@+id/btn_online"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="联机模式"
        android:textSize="25sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:layout_marginTop="30dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_single" />

    <!-- 添加到activity_main_menu.xml -->
    <Button
        android:id="@+id/btn_ranking"
        android:layout_width="200dp"
        android:layout_height="60dp"
        android:text="全球排行榜"
        android:textSize="25sp"
        android:textStyle="bold"
        android:fontFamily="serif"
        android:layout_marginTop="30dp"
        app:strokeColor="#FFFFFF"
        app:strokeWidth="4dp"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toBottomOf="@id/btn_online" />

</androidx.constraintlayout.widget.ConstraintLayout>